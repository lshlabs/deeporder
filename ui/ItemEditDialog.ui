  <property name="styleSheet">
   <string notr="true">QDialog {
    background: #EFEFEF;
}
QFrame#card {
    background: #ffffff;
    border: 1px solid #2f2f2f;
    border-radius: 10px;
}
QLabel, QLineEdit, QSpinBox {
    color: #111827;
}
QLineEdit, QSpinBox {
    min-height: 34px;
    border-radius: 8px;
    border: 1px solid #8e8e8e;
    background: #ffffff;
    padding: 0 8px;
}
QPushButton {
    min-height: 34px;
    padding: 0 14px;
    border-radius: 8px;
    border: 1px solid #8e8e8e;
    background: #f5f5f5;
    color: #111827;
}
QPushButton:hover {
    background: #e9eef5;
    border-color: #7d8ea3;
}
QPushButton#button_save {
    background: #17b4e7;
    border-color: #0d8fbc;
    color: white;
    font-weight: 700;
}
QPushButton#button_save:hover {
    background: #0ea5e9;
    border-color: #0284c7;
}
QLabel#preview_label {
    background: #f6f6f6;
    border: 1px solid #a4a4a4;
    border-radius: 8px;
    color: #6b7280;
}
QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 18px;
    background: #f0f0f0;
    border-left: 1px solid #c9c9c9;
    border-top-right-radius: 8px;
}
QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 18px;
    background: #f0f0f0;
    border-left: 1px solid #c9c9c9;
    border-top: 1px solid #c9c9c9;
    border-bottom-right-radius: 8px;
}
QSpinBox::up-button:hover, QSpinBox::down-button:hover {
    background: #e2e8f0;
}
QSpinBox::up-arrow {
    image: url(ui/chevron-up.svg);
    width: 10px;
    height: 10px;
}
QSpinBox::down-arrow {
    image: url(ui/chevron-down.svg);
    width: 10px;
    height: 10px;
}</string>
